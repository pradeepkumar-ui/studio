
{
  "entities": {
    "airlineAncillary": {
      "title": "Airline Ancillary SKU",
      "description": "Exhaustive portfolio item for airline-managed flight ancillaries.",
      "type": "object",
      "properties": {
        "airlineId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "pssCode": { "type": "string", "description": "Host PSS SSR identifier." },
        "defaultPrice": { "type": "number" },
        "currency": { "type": "string" },
        "cabinEligibility": { "type": "array", "items": { "type": "string" } },
        "aircraftEligibility": { "type": "array", "items": { "type": "string" }, "description": "Specific fleet types compatible with this service." },
        "refundPolicy": { "type": "string" },
        "advancePurchaseDays": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Disabled", "Testing"] }
      }
    },
    "airportAncillary": {
      "title": "Airport Ancillary SKU",
      "description": "Exhaustive portfolio item for airport-managed and partner services.",
      "type": "object",
      "properties": {
        "airportId": { "type": "string" },
        "providerId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "terminal": { "type": "string" },
        "gate": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "stockType": { "type": "string", "enum": ["Digital", "Physical"] },
        "commissionRate": { "type": "number", "description": "SITA Platform commission percentage." },
        "operatingHours": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Draft"] }
      }
    },
    "order": {
      "title": "Order",
      "description": "Represents a customer order containing flights, ancillaries, and airport services.",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Pending", "Fulfilled", "Canceled", "Partially Fulfilled"] },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "source": { "type": "string", "enum": ["Web", "Mobile", "CUSS", "CUTE", "CUPPS"], "description": "The airport touchpoint that generated the order." },
        "airportCode": { "type": "string", "description": "IATA code of the airport where the order was fulfilled." },
        "payment": {
          "type": "object",
          "properties": {
            "method": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["Flight", "Baggage", "Seat", "Lounge", "Parking", "FastTrack", "Retail"] },
              "provider": { "type": "string", "description": "The airline or airport vendor providing the service." },
              "status": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        }
      }
    },
    "pricingRule": {
      "title": "Dynamic Pricing Rule",
      "description": "A deterministic policy for continuous pricing adjustments and commercial guardrails.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "trigger": { "type": "object" },
        "conditions": { "type": "object" },
        "action": { "type": "object" },
        "guardrails": { "type": "object" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Test"] }
      }
    },
    "stockItem": {
      "title": "Stock Item",
      "description": "Exhaustive inventory unit for air ancillaries or ecosystem services.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["Physical", "Digital", "Service_Capacity"] },
        "supplier": { "type": "string" },
        "available": { "type": "number" },
        "reserved": { "type": "number", "description": "Units held in active retailing carts." },
        "threshold": { "type": "number", "description": "Minimum stock level before alert." },
        "status": { "type": "string", "enum": ["In Stock", "Low Stock", "Out of Stock"] }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "/airports/{airportId}": { "schema": { "$ref": "#/entities/airport" }, "description": "Onboarded airports." },
    "/partners/{partnerId}": { "schema": { "$ref": "#/entities/partner" }, "description": "Airport retail and service partners." },
    "/airlines/{airlineId}": { "schema": { "$ref": "#/entities/airline" }, "description": "Participating airlines." },
    "/orders/{orderId}": { "schema": { "$ref": "#/entities/order" }, "description": "Orders including airport touchpoint metadata." },
    "/cohorts/{cohortId}": { "schema": { "$ref": "#/entities/cohort" }, "description": "Advanced ecosystem targeting cohorts." },
    "/bundles/{bundleId}": { "schema": { "$ref": "#/entities/bundle" }, "description": "Retailing offers and bundles." },
    "/pricingRules/{ruleId}": { "schema": { "$ref": "#/entities/pricingRule" }, "description": "Dynamic pricing and continuous pricing policies." },
    "/stock/{stockId}": { "schema": { "$ref": "#/entities/stockItem" }, "description": "Inventory and logistics matrix." },
    "/airlineAncillaries/{ancillaryId}": { "schema": { "$ref": "#/entities/airlineAncillary" }, "description": "Exhaustive airline portfolio skus." },
    "/airportServices/{ancillaryId}": { "schema": { "$ref": "#/entities/airportAncillary" }, "description": "Exhaustive airport ecosystem skus." }
  }
}
