{
  "entities": {
    "fare": {
      "title": "Fare",
      "description": "Represents a fare for a specific route and class.",
      "type": "object",
      "properties": {
        "route": {
          "type": "string",
          "description": "The route for the fare, e.g., JFK-LAX."
        },
        "class": {
          "type": "string",
          "description": "The class of the fare, e.g., Economy, Business."
        },
        "price": {
          "type": "number",
          "description": "The price of the fare."
        },
        "currency": {
          "type": "string",
          "description": "The currency of the price."
        },
        "status": {
          "type": "string",
          "description": "The status of the fare (e.g., Active, Draft, Inactive)."
        },
        "version": {
          "type": "number",
          "description": "The version number of the fare record."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the fare was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the fare was last updated."
        }
      },
      "required": ["route", "class", "price", "currency", "status", "version"]
    },
    "offer": {
      "title": "Offer",
      "description": "Represents a retail offer or promotion.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "scope": { "type": "string", "enum": ["Airline", "Brand", "Market", "Channel"] },
        "offerType": { "type": "string", "enum": ["Discount", "Fixed", "Step"] },
        "currency": { "type": "string" },
        "rounding": { "type": "string", "enum": ["None", "Round Half-Up", "Round Down"] },
        "criteria": { "type": "string" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Draft", "Expired"] },
        "version": { "type": "number" },
        "ttl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "scope", "offerType", "currency", "rounding", "criteria", "effectiveDate", "expiryDate", "status", "version"]
    },
    "promotion": {
      "title": "Promotion",
      "description": "Represents a promotional code pool.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "prefix": { "type": "string" },
        "poolSize": { "type": "number" },
        "usageType": { "type": "string", "enum": ["single", "multi", "unlimited"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Expired"] }
      },
      "required": ["name", "description", "prefix", "poolSize", "usageType", "expiryDate", "status"]
    },
    "fareProduct": {
      "title": "Fare Product",
      "description": "Represents a fare product or brand.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Draft"] },
        "version": { "type": "number" }
      },
      "required": ["name", "description", "status", "version"]
    },
    "bundle": {
      "title": "Ancillary Bundle",
      "description": "Represents a bundle of ancillary products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published", "Archived"] },
        "scope": { "type": "string" },
        "itemCount": { "type": "number" }
      },
      "required": ["name", "description", "status", "scope", "itemCount"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/fares/{fareId}": {
      "schema": {
        "$ref": "#/entities/fare"
      },
      "description": "Stores individual fare documents."
    },
    "/offers/{offerId}": {
      "schema": {
        "$ref": "#/entities/offer"
      },
      "description": "Stores offer configuration documents."
    },
    "/promotions/{promoId}": {
      "schema": {
        "$ref": "#/entities/promotion"
      },
      "description": "Stores promotional code pools and their configurations."
    },
    "/fareProducts/{productId}": {
      "schema": {
        "$ref": "#/entities/fareProduct"
      },
      "description": "Stores fare product (brand) documents."
    },
    "/bundles/{bundleId}": {
      "schema": {
        "$ref": "#/entities/bundle"
      },
      "description": "Stores ancillary bundle documents."
    }
  }
}
