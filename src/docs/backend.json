
{
  "entities": {
    "order": {
      "title": "Order",
      "description": "Represents a customer order containing flights, ancillaries, and airport services.",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Pending", "Fulfilled", "Canceled", "Partially Fulfilled"] },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "source": { "type": "string", "enum": ["Web", "Mobile", "CUSS", "CUTE", "CUPPS"], "description": "The airport touchpoint that generated the order." },
        "airportCode": { "type": "string", "description": "IATA code of the airport where the order was fulfilled." },
        "payment": {
          "type": "object",
          "properties": {
            "method": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["Flight", "Baggage", "Seat", "Lounge", "Parking", "FastTrack", "Retail"] },
              "provider": { "type": "string", "description": "The airline or airport vendor providing the service." },
              "status": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "auditTrail": { "type": "array", "items": { "type": "object", "properties": { "event": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" } } } }
      }
    },
    "airport": {
      "title": "Airport",
      "description": "An airport node in the Offersense ecosystem.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "iataCode": { "type": "string" },
        "location": { "type": "string" },
        "sitaEnabled": { "type": "boolean" },
        "terminals": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "Inactive"] }
      },
      "required": ["name", "iataCode", "status"]
    },
    "partner": {
      "title": "Airport Partner",
      "description": "An airport vendor providing non-air services (e.g., Retail, Parking).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "airportCode": { "type": "string" },
        "category": { "type": "string", "enum": ["F&B", "Retail", "Services", "Transport"] },
        "contactEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "airline": {
        "title": "Airline Participant",
        "description": "An airline integrated with Offersense for PSS syncing.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "icaoCode": { "type": "string" },
            "pssType": { "type": "string", "enum": ["Amadeus", "Sabre", "Navitaire", "Custom"] },
            "status": { "type": "string", "enum": ["Active", "Onboarding", "Inactive"] }
        }
    },
    "offer": {
      "title": "Offer",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Air", "Airport", "Combined"] },
        "sitaConfig": {
            "type": "object",
            "properties": {
                "displayOnKiosk": { "type": "boolean" },
                "qrPayloadType": { "type": "string", "enum": ["DeepLink", "VoucherCode"] }
            }
        }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "/airports/{airportId}": { "schema": { "$ref": "#/entities/airport" }, "description": "Onboarded airports." },
    "/partners/{partnerId}": { "schema": { "$ref": "#/entities/partner" }, "description": "Airport retail and service partners." },
    "/airlines/{airlineId}": { "schema": { "$ref": "#/entities/airline" }, "description": "Participating airlines." },
    "/orders/{orderId}": { "schema": { "$ref": "#/entities/order" }, "description": "Orders including airport touchpoint metadata." }
  }
}
