
{
  "entities": {
    "cohort": {
      "title": "Ecosystem Retailing Cohort",
      "description": "Exhaustive segment definition for personalized retailing orchestration including geo-spatial and channel targeting.",
      "type": "object",
      "properties": {
        "cohort_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["static", "dynamic", "predictive"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "priority": { "type": "number" },
        "ecosystemScope": {
          "type": "object",
          "properties": {
            "channels": { "type": "array", "items": { "type": "string" } },
            "regions": { "type": "array", "items": { "type": "string" } },
            "countries": { "type": "array", "items": { "type": "string" } },
            "pos": { "type": "array", "items": { "type": "string" } },
            "sectors": { "type": "array", "items": { "type": "string" } }
          }
        },
        "airlineRules": { "type": "object" },
        "airportRules": { "type": "object" },
        "outputs": { "type": "object" }
      }
    },
    "airlineAncillary": {
      "title": "Airline Ancillary SKU",
      "description": "Exhaustive portfolio item for airline-managed flight ancillaries.",
      "type": "object",
      "properties": {
        "airlineId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "pssCode": { "type": "string" },
        "defaultPrice": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "airportAncillary": {
      "title": "Airport Ancillary SKU",
      "description": "Exhaustive portfolio item for airport-managed and partner services.",
      "type": "object",
      "properties": {
        "airportId": { "type": "string" },
        "providerId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "airlineAncillaryInventory": {
      "title": "Airline Ancillary Inventory",
      "description": "Detailed stock and capacity control for flight-based ancillaries.",
      "type": "object",
      "properties": {
        "ancillaryId": { "type": "string" },
        "flightNumber": { "type": "string" },
        "available": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "airportAncillaryInventory": {
      "title": "Airport Ancillary Inventory",
      "description": "Detailed capacity control for airport ecosystem services.",
      "type": "object",
      "properties": {
        "ancillaryId": { "type": "string" },
        "airportCode": { "type": "string" },
        "available": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "order": {
      "title": "Order",
      "description": "Represents a customer order containing flights, ancillaries, and airport services.",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "amount": { "type": "number" },
        "source": { "type": "string" }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "/airports/{airportId}": { "schema": { "$ref": "#/entities/airport" }, "description": "Onboarded airports." },
    "/partners/{partnerId}": { "schema": { "$ref": "#/entities/partner" }, "description": "Airport retail and service partners." },
    "/airlines/{airlineId}": { "schema": { "$ref": "#/entities/airline" }, "description": "Participating airlines." },
    "/orders/{orderId}": { "schema": { "$ref": "#/entities/order" }, "description": "Orders including airport touchpoint metadata." },
    "/cohorts/{cohortId}": { "schema": { "$ref": "#/entities/cohort" }, "description": "Advanced ecosystem targeting cohorts." },
    "/bundles/{bundleId}": { "schema": { "$ref": "#/entities/bundle" }, "description": "Retailing offers and bundles." },
    "/pricingRules/{ruleId}": { "schema": { "$ref": "#/entities/pricingRule" }, "description": "Dynamic pricing and continuous pricing policies." },
    "/airlineInventory/{stockId}": { "schema": { "$ref": "#/entities/airlineAncillaryInventory" }, "description": "Carrier-specific ancillary stock." },
    "/airportInventory/{stockId}": { "schema": { "$ref": "#/entities/airportAncillaryInventory" }, "description": "Airport ecosystem ancillary stock." },
    "/airlineAncillaries/{ancillaryId}": { "schema": { "$ref": "#/entities/airlineAncillary" }, "description": "Exhaustive airline portfolio skus." },
    "/airportServices/{ancillaryId}": { "schema": { "$ref": "#/entities/airportAncillary" }, "description": "Exhaustive airport ecosystem skus." }
  }
}
