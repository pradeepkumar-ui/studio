
{
  "entities": {
    "cohort": {
      "title": "Ecosystem Retailing Cohort",
      "description": "Exhaustive segment definition for personalized retailing orchestration including geo-spatial and channel targeting.",
      "type": "object",
      "properties": {
        "cohort_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["static", "dynamic", "predictive"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "priority": { "type": "number" },
        "ecosystemScope": {
          "type": "object",
          "properties": {
            "channels": { "type": "array", "items": { "type": "string" } },
            "regions": { "type": "array", "items": { "type": "string" } },
            "countries": { "type": "array", "items": { "type": "string" } },
            "pos": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "bundle": {
      "title": "Retailing Offer",
      "description": "Core monetization entity combining products, dynamic pricing, and cohort targeting.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "domain": { "type": "string", "enum": ["Airline", "Airport", "Hybrid"] },
        "owningAirlineId": { "type": "string" },
        "owningAirportId": { "type": "string" },
        "offerType": { "type": "string", "enum": ["Single", "Bundle", "Upgrade", "Conditional"] },
        "version": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Published", "Archived"] },
        "priority": { "type": "number" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "isMandatory": { "type": "boolean" },
              "substitutionId": { "type": "string" }
            }
          }
        },
        "pricing": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["Static", "Dynamic", "Demand", "Time-based"] },
            "basePrice": { "type": "number" },
            "floorPrice": { "type": "number" },
            "ceilingPrice": { "type": "number" },
            "adjustmentType": { "type": "string", "enum": ["Percentage", "Fixed", "Multiplier"] },
            "adjustmentValue": { "type": "number" }
          }
        },
        "targeting": {
          "type": "object",
          "properties": {
            "cohortIds": { "type": "array", "items": { "type": "string" } },
            "conflictPriority": { "type": "number" }
          }
        }
      }
    },
    "airlineAncillary": {
      "title": "Airline Ancillary SKU",
      "description": "Exhaustive portfolio item for airline-managed flight ancillaries.",
      "type": "object",
      "properties": {
        "ancillaryCode": { "type": "string" },
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "airlineCode": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Draft"] },
        "version": { "type": "number" }
      }
    },
    "airportAncillary": {
      "title": "Airport Ancillary Master SKU",
      "description": "High-fidelity master definition for hub-managed and partner services.",
      "type": "object",
      "properties": {
        "ancillaryCode": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["slot-based", "on-demand", "request-based"] },
        "airlineCode": { "type": "string" },
        "airportCode": { "type": "string" },
        "providerName": { "type": "string" },
        "terminals": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Draft"] }
      }
    },
    "airlineInventory": {
      "title": "Airline Stock Registry",
      "description": "Operational inventory tracking for airline ancillaries including soft-holds and fulfillment source logic.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "supplier": { "type": "string" },
        "available": { "type": "number" },
        "reserved": { "type": "number" },
        "threshold": { "type": "number" },
        "fulfillmentSource": { "type": "string", "enum": ["Offersense", "PSS"] },
        "realTimePssSync": { "type": "boolean" },
        "type": { "type": "string", "enum": ["Physical", "Digital", "Service_Capacity"] },
        "status": { "type": "string", "enum": ["In Stock", "Low Stock", "Out of Stock"] }
      }
    },
    "airportInventory": {
      "title": "Airport Stock Registry",
      "description": "Operational inventory tracking for hub services including slot-based and capacity-based logic.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "airportCode": { "type": "string" },
        "terminal": { "type": "string" },
        "category": { "type": "string" },
        "fulfillmentSource": { "type": "string", "enum": ["Offersense", "Supplier_API"] },
        "protocol": { "type": "string", "enum": ["Slot-based", "Capacity-based", "Resource-count"] },
        "available": { "type": "number" },
        "reserved": { "type": "number" },
        "threshold": { "type": "number" },
        "realTimeSync": { "type": "boolean" },
        "status": { "type": "string", "enum": ["In Stock", "Low Stock", "Out of Stock"] }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "/airports/{airportId}": { "schema": { "$ref": "#/entities/airport" }, "description": "Onboarded airports." },
    "/airlines/{airlineId}": { "schema": { "$ref": "#/entities/airline" }, "description": "Participating airlines." },
    "/orders/{orderId}": { "schema": { "$ref": "#/entities/order" }, "description": "Orders including touchpoint metadata." },
    "/cohorts/{cohortId}": { "schema": { "$ref": "#/entities/cohort" }, "description": "Advanced ecosystem targeting cohorts." },
    "/bundles/{bundleId}": { "schema": { "$ref": "#/entities/bundle" }, "description": "Core monetization engine offers." },
    "/airlineAncillaries/{ancillaryId}": { "schema": { "$ref": "#/entities/airlineAncillary" }, "description": "Airline skus." },
    "/airportServices/{ancillaryId}": { "schema": { "$ref": "#/entities/airportAncillary" }, "description": "Airport ecosystem skus." },
    "/airlineInventory/{inventoryId}": { "schema": { "$ref": "#/entities/airlineInventory" }, "description": "Airline operational stock keeper." },
    "/airportInventory/{inventoryId}": { "schema": { "$ref": "#/entities/airportInventory" }, "description": "Airport operational stock keeper." }
  }
}
