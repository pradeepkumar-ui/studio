
{
  "entities": {
    "order": {
      "title": "Order",
      "description": "Represents a customer order containing flights, ancillaries, and airport services.",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Pending", "Fulfilled", "Canceled", "Partially Fulfilled"] },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "source": { "type": "string", "enum": ["Web", "Mobile", "CUSS", "CUTE", "CUPPS"], "description": "The airport touchpoint that generated the order." },
        "airportCode": { "type": "string", "description": "IATA code of the airport where the order was fulfilled." },
        "payment": {
          "type": "object",
          "properties": {
            "method": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["Flight", "Baggage", "Seat", "Lounge", "Parking", "FastTrack", "Retail"] },
              "provider": { "type": "string", "description": "The airline or airport vendor providing the service." },
              "status": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "auditTrail": { "type": "array", "items": { "type": "object", "properties": { "event": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" } } } }
      }
    },
    "airport": {
      "title": "Airport",
      "description": "An airport node in the Offersense ecosystem.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "iataCode": { "type": "string" },
        "location": { "type": "string" },
        "sitaEnabled": { "type": "boolean" },
        "terminals": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "Inactive"] }
      },
      "required": ["name", "iataCode", "status"]
    },
    "partner": {
      "title": "Airport Partner",
      "description": "An airport vendor providing non-air services (e.g., Retail, Parking).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "airportCode": { "type": "string" },
        "category": { "type": "string", "enum": ["F&B", "Retail", "Services", "Transport"] },
        "contactEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "airline": {
        "title": "Airline Participant",
        "description": "An airline integrated with Offersense for PSS syncing.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "icaoCode": { "type": "string" },
            "pssType": { "type": "string", "enum": ["Amadeus", "Sabre", "Navitaire", "Custom"] },
            "status": { "type": "string", "enum": ["Active", "Onboarding", "Inactive"] }
        }
    },
    "cohort": {
        "title": "Customer Cohort",
        "description": "A dynamic segment of passengers targeted for specific offers based on exhaustive ecosystem context.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "cohortId": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["Active", "Inactive"] },
            "definition": {
                "type": "object",
                "properties": {
                    "channels": { "type": "array", "items": { "type": "string" } },
                    "airports": { "type": "array", "items": { "type": "string" } },
                    "airlines": { "type": "array", "items": { "type": "string" } },
                    "cabinClasses": { "type": "array", "items": { "type": "string" } },
                    "fareBrands": { "type": "array", "items": { "type": "string" } },
                    "travelGroup": { "type": "array", "items": { "type": "string" } },
                    "transitStatus": { "type": "string", "enum": ["Any", "Origin", "Transit", "Destination"] },
                    "connectionWindow": { "type": "object", "properties": { "min": { "type": "number" }, "max": { "type": "number" } } }
                }
            }
        }
    },
    "airlineAncillary": {
      "title": "Airline Ancillary",
      "description": "A flight-related upsell service (e.g. Baggage, Wi-Fi).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Baggage", "Seat", "On-board", "Flexibility"] },
        "pssCode": { "type": "string" },
        "defaultPrice": { "type": "number" },
        "currency": { "type": "string" },
        "cabinEligibility": { "type": "array", "items": { "type": "string" } }
      }
    },
    "airportService": {
      "title": "Airport Service",
      "description": "A non-air ecosystem service provided by airport partners.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "providerId": { "type": "string" },
        "airportCode": { "type": "string" },
        "category": { "type": "string", "enum": ["Lounge", "Parking", "Retail", "Voucher", "Merchandise", "F&B"] },
        "stockType": { "type": "string", "enum": ["Digital", "Physical"] },
        "commissionRate": { "type": "number" }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "/airports/{airportId}": { "schema": { "$ref": "#/entities/airport" }, "description": "Onboarded airports." },
    "/partners/{partnerId}": { "schema": { "$ref": "#/entities/partner" }, "description": "Airport retail and service partners." },
    "/airlines/{airlineId}": { "schema": { "$ref": "#/entities/airline" }, "description": "Participating airlines." },
    "/orders/{orderId}": { "schema": { "$ref": "#/entities/order" }, "description": "Orders including airport touchpoint metadata." },
    "/cohorts/{cohortId}": { "schema": { "$ref": "#/entities/cohort" }, "description": "Advanced ecosystem targeting cohorts." },
    "/airlineAncillaries/{ancillaryId}": { "schema": { "$ref": "#/entities/airlineAncillary" }, "description": "Flight-related service portfolio." },
    "/airportServices/{serviceId}": { "schema": { "$ref": "#/entities/airportService" }, "description": "Non-air airport partner services." }
  }
}
